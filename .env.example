# Go server configuration
JWT_SECRET=changeme-use-openssl-rand-hex-32
DATABASE_URL=postgres://username:password@localhost:5432/relay?sslmode=disable
RETENTION_DAYS=30

# Docker Compose configuration (PostgreSQL container)
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=relay
POSTGRES_HOST=localhost
POSTGRES_PORT=5432